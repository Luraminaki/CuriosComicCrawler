{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.1.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "CC",
            "type": "debugpy",
            "request": "launch",
            "module": "curios_comic_crawler.cli_launcher",
            "args": ["--configuration=${workspaceFolder}/config.json"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "DCC",
            "type": "debugpy",
            "request": "launch",
            "module": "curios_comic_crawler.cli_download",
            "args": ["--configuration=${workspaceFolder}/config.json"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "UCC",
            "type": "debugpy",
            "request": "launch",
            "module": "curios_comic_crawler.cli_upscale",
            "args": ["--configuration=${workspaceFolder}/config.json"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ],
    "compounds": [
        {
            "name": "Soon",
            "configurations": [
                "DCC",
                "UCC"
            ]
        }
    ]
}
